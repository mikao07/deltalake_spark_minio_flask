## 複製為 .env 後依環境修改（勿將含真實密碼的 .env 提交版本庫）
## docker compose 會讀取 .env；變數可在 shell 或 CI 覆寫

# ---------------------------------------------------------------------------
# MinIO / S3（必填：ACCESS / SECRET；其餘可選）
# ---------------------------------------------------------------------------
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key

# Spark S3A 用；可為 http://host:port 或 host:port
MINIO_ENDPOINT=127.0.0.1:9000
# MinIO SDK / 部分客戶端用；通常為 host:port（不含 http://）
MINIO_ENDPOINT_CLIENT=127.0.0.1:9000

# ---------------------------------------------------------------------------
# docker-compose.yml（僅起 web，連「外部」MinIO）
# 請改為容器內可連到的位址，例如區網或 host.docker.internal
# ---------------------------------------------------------------------------
# compose build 後的映像名稱（預設對齊 Docker Hub；可改為你的 帳號/倉庫:tag）
# DOCKER_IMAGE=mikao07/deltalake_spark_minio_flask:latest
# MINIO_ENDPOINT=http://192.168.1.100:9000
# MINIO_ENDPOINT_CLIENT=192.168.1.100:9000
# 若 MinIO 跑在宿主機、埠 9000（Windows / Mac Docker Desktop）可嘗試：
# MINIO_ENDPOINT=http://host.docker.internal:9000
# MINIO_ENDPOINT_CLIENT=host.docker.internal:9000

# ---------------------------------------------------------------------------
# docker-compose(new_minio).yml / docker-compose - ubuntu.yml
# （同一份 compose 內含 MinIO 服務名 minio 時請用）
# ---------------------------------------------------------------------------
# MINIO_ENDPOINT=http://minio:9000
# MINIO_ENDPOINT_CLIENT=minio:9000
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin

# ---------------------------------------------------------------------------
# S3A / Spark（連 MinIO 時多為 path-style、關 SSL）
# ---------------------------------------------------------------------------
S3A_PATH_STYLE_ACCESS=true
S3A_IMPL=org.apache.hadoop.fs.s3a.S3AFileSystem
S3A_ENDPOINT_REGION=us-east-1
S3A_CONNECTION_SSL_ENABLED=false

# ---------------------------------------------------------------------------
# Delta Lake 路徑（若改 BUCKET_NAME，請一併調整下列 s3a:// 路徑）
# ---------------------------------------------------------------------------
BUCKET_NAME=data-lake
BRONZE_TABLE_PATH=s3a://data-lake/bronze/raw_features/
SILVER_TABLE_PATH=s3a://data-lake/silver/cleaned_features/
SILVER_OCR_TABLE_PATH=s3a://data-lake/silver/ocr_features/
# 痛點主題快照（首頁圖表、topic-snapshot API）
GOLD_TOPIC_SNAPSHOT_PATH=s3a://data-lake/gold/topic_snapshot/
# Phase A：TF-IDF 痛點候選詞
GOLD_TFIDF_KEYWORDS_PATH=s3a://data-lake/gold/tfidf_keywords/
# Phase B：PMI 片語候選
GOLD_PHRASE_CANDIDATES_PATH=s3a://data-lake/gold/phrase_candidates/
# 寫入痛點快照後是否強制讀表驗證（true=較安全；表極大或除錯可設 false）
GOLD_TOPIC_SNAPSHOT_VERIFY_AFTER_WRITE=true

# 可留空（預設用環境已安裝 jieba）；executors 無 jieba 時再指定 zip
# JIEBA_ZIP_PATH=s3a://data-lake/jars/dependencies/jieba.zip
# 全域自訂辭典（本機路徑或 s3a://）
# JIEBA_USERDICT_PATH=s3a://data-lake/dic/jieba_userdict.txt
# 依 dataset_id 綁定辭典；{dataset_id} 會替換為實際分類名
# JIEBA_USERDICT_DATASET_PATTERN=s3a://data-lake/dic/jieba_dicts/{dataset_id}.txt
# 全域停用詞表（每行一詞；# 開頭為註解）
# STOPWORDS_PATH=s3a://data-lake/dic/stopwords.txt
# 依 dataset_id 綁定停用詞（Gold lexicon；支援 {dataset_id}、{version}）
# STOPWORDS_DATASET_PATTERN=s3a://data-lake/dic/stop_words/{version}/{dataset_id}.txt
# STOPWORDS_LEXICON_VERSION=v1.0.0
# STOPWORDS_EXPLORATION_LEXICON_VERSION=dev
RAW_IMAGE_PREFIX=raw/images/
RAW_IMAGES_PATH=s3a://data-lake/raw/images/

# ---------------------------------------------------------------------------
# OCR（Docker 映像已含 chi_tra + eng；Windows 本機可指定執行檔）
# ---------------------------------------------------------------------------
# 語言包：繁中 + 英文
OCR_LANG=chi_tra+eng
# Page Segmentation Mode：6=單一文字區塊（AB 實測較少 emoji 亂碼）；11=稀疏文字；3=全自動
OCR_PSM=6
# 前處理（drinks 深色截圖實測：不放大較佳；詳見 docs/問題日誌.md）
OCR_SCALE_MIN_SIDE=0
OCR_CONTRAST=1.5
OCR_SHARPNESS=1.0
OCR_BINARIZE=off
# Windows 本機可指向 tesseract.exe；Docker / Linux 通常留空
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
# 前處理版本標記，會寫入 Bronze 的 ocr_signature（改任一 OCR 參數後請 bump）
OCR_PREPROCESS_VERSION=v1.1
# 實驗用（小字／模糊圖可個別試，深色 UI 截圖可能變差）：
# OCR_SCALE_MIN_SIDE=1600
# OCR_CONTRAST=1.8
# OCR_SHARPNESS=1.2
# OCR_PREPROCESS_VERSION=v2
# 二值化：off | otsu | adaptive（彩色 UI 截圖可試 otsu）
# OCR_BINARIZE=otsu
# OCR_BINARIZE_INVERT=auto
# OCR_BINARIZE_BLOCK_SIZE=31
# OCR_BINARIZE_C=10
# Tesseract user-words（全域或依 dataset_id）
# OCR_USER_WORDS_PATH=s3a://data-lake/dic/ocr_user_words/drinks.txt
# OCR_USER_WORDS_DATASET_PATTERN=s3a://data-lake/dic/ocr_user_words/{dataset_id}.txt
# 自訂 OCR 簽章；留空則由 lang / psm / pre / profile 自動組成
# OCR_SIGNATURE=

# 前處理 preset 分流（預設 false；第一次 Bronze 即內建 router，避免二次 overwrite）
# OCR_PRESET_ROUTER_ENABLED=false
# OCR_LOW_RES_SHORT_SIDE=720
# OCR_LOW_RES_TARGET_SIDE=1080
# OCR_LIGHT_DOC_MEAN_LUMA=180

# OCR PSM A/B 測試頁（/test/ocr-psm；結果寫入 test 路徑，可整包刪除）
# OCR_AB_SAMPLE_SIZE=20
# OCR_AB_MAX_SAMPLE_SIZE=50
# OCR_AB_RESULTS_PATH=s3a://data-lake/test/ocr_psm_ab/

# ---------------------------------------------------------------------------
# 痛點主題（Gold 規則式分類）
# ---------------------------------------------------------------------------
# PAIN_FUZZY_ENABLED=true
# PAIN_FUZZY_MIN_RATIO=0.78
# PAIN_FUZZY_ANCHOR_RATIO=0.88
# PAIN_FUZZY_MIN_CHARS=3

# ---------------------------------------------------------------------------
# 上傳至 MinIO（僅靜態截圖；影片在 API 層拒絕，見 services/media_validation.py）
# ---------------------------------------------------------------------------
# 同名物件已存在：suffix=改檔名加時間戳（預設）；overwrite=直接覆寫
UPLOAD_ON_DUPLICATE=suffix
# 單檔上傳大小上限（MB）；類型：PNG/JPEG/GIF/BMP/WEBP/TIFF
MAX_UPLOAD_MB=15

# ---------------------------------------------------------------------------
# Resource Guard（P3：Request / Pipeline / Runtime 三層資源保護）
# ---------------------------------------------------------------------------
# 單次 multipart 檔案數上限（單檔仍受 MAX_UPLOAD_MB 限制）
MAX_UPLOAD_FILES_PER_REQUEST=20
# 單次 Bronze OCR 處理圖片數上限（依 dataset 或 image_paths 估算）
MAX_BRONZE_OCR_IMAGES=100
# P4：MinIO SDK fallback 每批讀圖數（不超過 MAX_BRONZE_OCR_IMAGES）
OCR_MINIO_BATCH_SIZE=20
# 同時執行的 ETL 工作數（Bronze／Silver／Gold／一鍵管線共用槽位）
ETL_MAX_CONCURRENT_JOBS=1
# Runtime：記憶體使用率上限（%）與可用 MB 下限（Docker 內 psutil 看容器配額）
ETL_MEMORY_MAX_PERCENT=85
ETL_MEMORY_MIN_AVAILABLE_MB=1536
ETL_RESOURCE_GUARD_ENABLED=true
# Spark local 模式（driver 為主）
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g
SPARK_DRIVER_MAX_RESULT_SIZE=512m
# P4 執行期節流（0=關閉該項；預設與現況相同）
# 單張 OCR 逾時（executor 內；逾時列記為 OCR_ERROR_TIMEOUT 並由 Bronze 統計丟棄）
OCR_TIMEOUT_SECONDS=30
# 整段 ETL slot 逾時（逾時 cancelAllJobs + 400）
SPARK_JOB_TIMEOUT_SECONDS=300
# Bronze OCR 前 repartition（0=不強制；擴量時建議設為 CPU 核心數）
OCR_REPARTITION=0

# ---------------------------------------------------------------------------
# Flask / 日誌 / 埠（對外對應 WEB_PORT）
# ---------------------------------------------------------------------------
PORT=5000
WEB_PORT=5000
FLASK_DEBUG=false
LOG_LEVEL=INFO
# GET /ready 是否預設包含 Spark 檢查（冷啟動較慢；存活探針建議用 GET /health）
READY_CHECK_INCLUDE_SPARK=false

# 銀層轉換版本（冪等合約；變更清洗邏輯時 bump）
SILVER_TRANSFORM_VERSION=v2.1.0
# 銀層品質閘門（ETL 後三道防線）
SILVER_QUALITY_ENABLED=true
SILVER_QUALITY_FAIL_ON_HARD=true
SILVER_QUALITY_MAX_NOISE_ROW_RATIO=0.001

# Bronze 列級隔離（Silver ETL 前；三層熔斷）
BRONZE_QUARANTINE_ENABLED=true
# BRONZE_QUARANTINE_PATH=s3a://data-lake/bronze/quarantine/
# merge 子集前自動歸檔舊列（懶建立；封板後第一次 merge 才會產生 history 表）
BRONZE_HISTORY_ON_MERGE=true
# BRONZE_HISTORY_PATH=s3a://data-lake/bronze/history/
# 軟熔斷下限（>10% 觸發；好列仍進 Silver、擋核准）
# BRONZE_QUARANTINE_MAX_REJECT_RATE=0.10
# 硬熔斷紅線（≥30% 不進 Silver）
# BRONZE_QUARANTINE_HARD_REJECT_RATE=0.30
# 熔斷模式：soft（預設）| hard（>軟門檻即硬停）
# BRONZE_QUARANTINE_MELT_MODE=soft
# BRONZE_QUARANTINE_MIN_TEXT_LEN=4

# ---------------------------------------------------------------------------
# ETL 指標（本機 JSONL；GET /api/metrics/etl 需 ADMIN_TOKEN 時）
# ---------------------------------------------------------------------------
ETL_METRICS_FILE=var/etl_metrics.jsonl

# ---------------------------------------------------------------------------
# 安全與路徑白名單（開發階段可維持註解；上線前建議啟用）
# ---------------------------------------------------------------------------
# 設定後，寫入／ETL／上傳等 API 需帶 header：X-Admin-Token
# ADMIN_TOKEN=change_me
# Delta 讀寫允許的 s3a 前綴（逗號分隔）；未設時預設僅 s3a://<BUCKET_NAME>/
# ALLOWED_DELTA_PATH_PREFIXES=s3a://data-lake/

# ---------------------------------------------------------------------------
# 管線探針／告警（cron：scripts/pipeline_probe.py）
# ---------------------------------------------------------------------------
# PIPELINE_PROBE_LAST_FILE=var/pipeline_probe_last.json
# 若探針在容器外跑、改打 HTTP：PIPELINE_PROBE_READY_URL=http://127.0.0.1:5000/ready?spark=true
# 通知後端：none | discord | line_messaging（line / line_notify 同義）
PIPELINE_NOTIFY_BACKEND=none
# Discord Incoming Webhook（backend=discord）
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# 或通用 webhook URL（與 DISCORD_WEBHOOK_URL 二擇一）
# PIPELINE_NOTIFY_WEBHOOK_URL=
# LINE Messaging API（Notify 已停服；Bot push 至個人）
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_PUSH_USER_ID=
# 新鮮度滯後門檻（小時）
# FRESHNESS_STALE_HOURS=12

# ---------------------------------------------------------------------------
# MinIO 容器對外埠（僅含 minio 服務的 compose）
# ---------------------------------------------------------------------------
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001
